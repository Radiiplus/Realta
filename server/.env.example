SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

SUPABASE_PORTAL_TABLE=realta
SUPABASE_PORTAL_ROW_ID=realtadb
SUPABASE_STORAGE_BUCKET=realta
SUPABASE_STORAGE_UPLOADS_PREFIX=uploads

PORT=8787
HOST=127.0.0.1
DEFAULT_NETWORK=devnet
CKB_RPC_DEVNET=http://127.0.0.1:8114
CKB_RPC_TESTNET=https://testnet.ckb.dev
CKB_RPC_MAINNET=

# Active NDCP contract metadata per network
CKB_NDCP_DEVNET_CODE_HASH=
CKB_NDCP_DEVNET_HASH_TYPE=data2
CKB_NDCP_DEVNET_TX_HASH=
CKB_NDCP_DEVNET_INDEX=0x0
CKB_NDCP_DEVNET_DEP_TYPE=code

CKB_NDCP_TESTNET_CODE_HASH=
CKB_NDCP_TESTNET_HASH_TYPE=data2
CKB_NDCP_TESTNET_TX_HASH=
CKB_NDCP_TESTNET_INDEX=0x0
CKB_NDCP_TESTNET_DEP_TYPE=code

CKB_NDCP_MAINNET_CODE_HASH=
CKB_NDCP_MAINNET_HASH_TYPE=data2
CKB_NDCP_MAINNET_TX_HASH=
CKB_NDCP_MAINNET_INDEX=0x0
CKB_NDCP_MAINNET_DEP_TYPE=code

# Secp256k1 lock cell deps per network
CKB_SECP256K1_CELL_DEP_DEVNET_TX_HASH=
CKB_SECP256K1_CELL_DEP_DEVNET_INDEX=0x0
CKB_SECP256K1_CELL_DEP_DEVNET_DEP_TYPE=dep_group

CKB_SECP256K1_CELL_DEP_TESTNET_TX_HASH=
CKB_SECP256K1_CELL_DEP_TESTNET_INDEX=0x0
CKB_SECP256K1_CELL_DEP_TESTNET_DEP_TYPE=dep_group

CKB_SECP256K1_CELL_DEP_MAINNET_TX_HASH=
CKB_SECP256K1_CELL_DEP_MAINNET_INDEX=0x0
CKB_SECP256K1_CELL_DEP_MAINNET_DEP_TYPE=dep_group
